{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dsp.local/schemas/lab01/user.schema.json",
  "title": "User",
  "description": "Lab01 Film Manager user data structure.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "email"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "password": {
      "type": "string",
      "minLength": 6,
      "maxLength": 20
    }
  }
}
